generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  hashedPassword String
  role           String   @default("consumer")
  company        String?
  isDemo         Boolean  @default(false)
  verified       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bids          Bid[]
  asks          Ask[]
  facilities    ProductionFacility[]
  certificates  Certificate[]
  notifications Notification[]
  auditLogs     AuditLog[]  @relation("AuditActor")
  sessions      Session[]
  accounts      Account[]

  // Emissions & Marketplace relations
  emissionsInventories   EmissionsInventory[]
  abatementTargets       AbatementTarget[]
  bookClaimPurchases     BookClaimTransaction[] @relation("BookClaimBuyer")
  bookClaimSales         BookClaimTransaction[] @relation("BookClaimSeller")
  demandPoolParticipants DemandPoolParticipant[]

  @@index([role])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// PRODUCTION FACILITIES
// ============================================================

model ProductionFacility {
  id             String   @id @default(cuid())
  producerId     String
  name           String
  location       String
  safCategory    String
  annualCapacity Float
  ciScore        Float
  certifications String   @default("[]")
  feedstock      String
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  producer     User          @relation(fields: [producerId], references: [id])
  asks         Ask[]
  certificates Certificate[]

  @@index([producerId])
  @@index([safCategory])
}

// ============================================================
// AUCTIONS
// ============================================================

model Auction {
  id                 String   @id @default(cuid())
  title              String
  description        String?
  status             String   @default("draft")
  auctionType        String   @default("vickrey")
  categories         String   @default("[]")
  startTime          DateTime
  endTime            DateTime
  reservePricePerGal Float?
  aggregateReserve   Float?
  minBidQuantity     Float    @default(0)
  maxBidQuantity     Float?
  substitutionMatrix String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  bids           Bid[]
  asks           Ask[]
  auctionResults AuctionResult[]
  allocations    Allocation[]
  demandPools    DemandPool[]

  @@index([status])
  @@index([startTime])
}

// ============================================================
// BIDS (Consumer submits)
// ============================================================

model Bid {
  id                  String   @id @default(cuid())
  auctionId           String
  bidderId            String
  safCategory         String
  quantity            Float
  maxPrice            Float
  categoryPreferences String?
  allowSubstitution   Boolean  @default(false)
  status              String   @default("active")
  isSealed            Boolean  @default(true)
  clearedPrice        Float?
  clearedQuantity     Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  auction     Auction      @relation(fields: [auctionId], references: [id])
  bidder      User         @relation(fields: [bidderId], references: [id])
  allocations Allocation[]

  @@index([auctionId])
  @@index([bidderId])
  @@index([auctionId, safCategory])
}

// ============================================================
// ASKS (Producer submits)
// ============================================================

model Ask {
  id              String   @id @default(cuid())
  auctionId       String
  producerId      String
  facilityId      String?
  safCategory     String
  quantity        Float
  minPrice        Float
  categoryOffers  String?
  status          String   @default("active")
  isSealed        Boolean  @default(true)
  clearedPrice    Float?
  clearedQuantity Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  auction     Auction             @relation(fields: [auctionId], references: [id])
  producer    User                @relation(fields: [producerId], references: [id])
  facility    ProductionFacility? @relation(fields: [facilityId], references: [id])
  allocations Allocation[]

  @@index([auctionId])
  @@index([producerId])
  @@index([auctionId, safCategory])
}

// ============================================================
// AUCTION RESULTS
// ============================================================

model AuctionResult {
  id              String   @id @default(cuid())
  auctionId       String
  mechanism       String
  totalVolume     Float
  totalValue      Float
  averagePrice    Float
  categoryResults String
  socialWelfare   Float?
  revenueRatio    Float?
  reserveMet      Boolean  @default(true)
  clearedAt       DateTime @default(now())

  auction     Auction      @relation(fields: [auctionId], references: [id])
  allocations Allocation[]

  @@index([auctionId])
}

// ============================================================
// ALLOCATIONS
// ============================================================

model Allocation {
  id              String   @id @default(cuid())
  auctionResultId String
  auctionId       String
  bidId           String
  askId           String
  safCategory     String
  quantity        Float
  pricePerGallon  Float
  totalPrice      Float
  vcgPayment      Float?
  status          String   @default("pending")
  createdAt       DateTime @default(now())

  auctionResult AuctionResult @relation(fields: [auctionResultId], references: [id])
  auction       Auction       @relation(fields: [auctionId], references: [id])
  bid           Bid           @relation(fields: [bidId], references: [id])
  ask           Ask           @relation(fields: [askId], references: [id])
  certificate   Certificate?

  @@index([auctionResultId])
  @@index([bidId])
  @@index([askId])
}

// ============================================================
// CERTIFICATES (Phase 3)
// ============================================================

model Certificate {
  id                 String    @id @default(cuid())
  holderId           String
  facilityId         String?
  allocationId       String?   @unique
  certType           String
  certNumber         String    @unique
  registryScheme     String?
  safCategory        String
  quantity           Float
  ciScore            Float?
  vintageYear        Int
  verificationStatus String    @default("pending")
  verifiedAt         DateTime?
  expiresAt          DateTime?
  documentPath       String?
  metadata           String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  holder     User                @relation(fields: [holderId], references: [id])
  facility   ProductionFacility? @relation(fields: [facilityId], references: [id])
  allocation Allocation?         @relation(fields: [allocationId], references: [id])
  bookClaimTransactions BookClaimTransaction[]

  @@index([holderId])
  @@index([certType])
  @@index([verificationStatus])
}

// ============================================================
// AUDIT LOG (Phase 4)
// ============================================================

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}

// ============================================================
// NOTIFICATIONS (Phase 4)
// ============================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([createdAt])
}

// ============================================================
// SECTORS & ABATEMENT TYPES
// ============================================================

model Sector {
  id    String @id @default(cuid())
  code  String @unique
  name  String
  color String
  icon  String

  abatementTypes       AbatementType[]
  emissionEntries      EmissionEntry[]
  abatementTargets     AbatementTarget[]
  bookClaimTransactions BookClaimTransaction[]
  demandPools          DemandPool[]
}

model AbatementType {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?
  unit        String  @default("tCO2e")
  sectorCode  String
  ciReduction Float?
  isVerified  Boolean @default(true)

  sector               Sector                @relation(fields: [sectorCode], references: [code])
  bookClaimTransactions BookClaimTransaction[]
  demandPools          DemandPool[]

  @@index([sectorCode])
}

// ============================================================
// EMISSIONS TRACKING
// ============================================================

model EmissionsInventory {
  id           String   @id @default(cuid())
  userId       String
  year         Int
  scope1Total  Float    @default(0)
  scope2Total  Float    @default(0)
  scope3Total  Float    @default(0)
  baselineYear Boolean  @default(false)
  status       String   @default("draft") // draft, submitted, verified
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id])
  entries EmissionEntry[]

  @@unique([userId, year])
  @@index([userId])
  @@index([year])
}

model EmissionEntry {
  id             String   @id @default(cuid())
  inventoryId    String
  scope          Int      // 1, 2, 3
  ghgCategory    String   // e.g. "scope3_cat6" for business travel
  sectorCode     String
  description    String
  activityData   Float?   // quantity of activity (e.g. km traveled, kWh used)
  activityUnit   String?  // unit of activity data
  emissionFactor Float?   // kgCO2e per unit
  tCO2e          Float    // total emissions in tonnes CO2e
  source         String?  // data source
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  inventory EmissionsInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  sector    Sector             @relation(fields: [sectorCode], references: [code])

  @@index([inventoryId])
  @@index([scope])
  @@index([sectorCode])
  @@index([ghgCategory])
}

// ============================================================
// ABATEMENT TARGETS
// ============================================================

model AbatementTarget {
  id               String   @id @default(cuid())
  userId           String
  sectorCode       String
  year             Int
  targetReduction  Float    // target tCO2e to reduce
  currentReduction Float    @default(0) // achieved so far
  status           String   @default("active") // active, achieved, missed
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  sector Sector @relation(fields: [sectorCode], references: [code])

  @@unique([userId, sectorCode, year])
  @@index([userId])
  @@index([sectorCode])
}

// ============================================================
// BOOK & CLAIM TRANSACTIONS
// ============================================================

model BookClaimTransaction {
  id                String    @id @default(cuid())
  buyerId           String?
  sellerId          String
  certificateId     String?
  abatementTypeCode String
  sectorCode        String
  quantity          Float     // tCO2e
  pricePerUnit      Float?
  totalPrice        Float?
  status            String    @default("registered") // registered, listed, purchased, claimed, retired, cancelled
  registeredAt      DateTime  @default(now())
  listedAt          DateTime?
  purchasedAt       DateTime?
  claimedAt         DateTime?
  retiredAt         DateTime?
  poolId            String?
  metadata          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  buyer         User?         @relation("BookClaimBuyer", fields: [buyerId], references: [id])
  seller        User          @relation("BookClaimSeller", fields: [sellerId], references: [id])
  certificate   Certificate?  @relation(fields: [certificateId], references: [id])
  abatementType AbatementType @relation(fields: [abatementTypeCode], references: [code])
  sector        Sector        @relation(fields: [sectorCode], references: [code])
  demandPool    DemandPool?   @relation(fields: [poolId], references: [id])

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([sectorCode])
  @@index([abatementTypeCode])
}

// ============================================================
// DEMAND POOLS (Collective Purchasing)
// ============================================================

model DemandPool {
  id                String    @id @default(cuid())
  name              String
  description       String?
  sectorCode        String
  abatementTypeCode String
  targetQuantity    Float     // total tCO2e desired
  currentQuantity   Float     @default(0)
  maxPricePerUnit   Float?
  status            String    @default("forming") // forming, active, clearing, completed, cancelled
  auctionId         String?
  deadline          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sector        Sector        @relation(fields: [sectorCode], references: [code])
  abatementType AbatementType @relation(fields: [abatementTypeCode], references: [code])
  auction       Auction?      @relation(fields: [auctionId], references: [id])
  participants  DemandPoolParticipant[]
  transactions  BookClaimTransaction[]

  @@index([sectorCode])
  @@index([status])
  @@index([abatementTypeCode])
}

model DemandPoolParticipant {
  id                String   @id @default(cuid())
  poolId            String
  userId            String
  committedQuantity Float    // tCO2e this participant wants
  allocatedQuantity Float    @default(0)
  status            String   @default("committed") // committed, allocated, withdrawn
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  pool DemandPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id])

  @@unique([poolId, userId])
  @@index([poolId])
  @@index([userId])
}
